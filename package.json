{
  "name": "playwright-network-cache",
  "description": "Cache network requests in Playwright tests",
  "version": "0.2.2",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git://github.com/vitalets/playwright-network-cache.git"
  },
  "funding": "https://github.com/sponsors/vitalets",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath scripts/git-hooks",
    "lint": "eslint .",
    "tsc": "tsc",
    "knip": "knip -c knip.config.ts",
    "prettier": "prettier --check --ignore-unknown .",
    "prettier:w": "prettier --write --ignore-unknown .",
    "test": "npx playwright test",
    "test:d": "DEBUG=playwright-network-cache npm test",
    "pw": "npm i --no-save --min-release-age=0 @playwright/test@$PW",
    "pw:install": "npx cross-env PLAYWRIGHT_SKIP_BROWSER_GC=1 npx playwright install chromium",
    "example": "npx playwright test -c example",
    "example:debug": "DEBUG=playwright-network-cache npx playwright test -c example",
    "example:nocache": "rm -rf .network-cache && npx playwright test -c example",
    "example:serve": "npx ts-node ./example/src/server",
    "toc": "md-magic --files README.md",
    "deps": "npx npm-check-updates -i --format group,dep,repo --cooldown 5",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "release": "release-it"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.55.1",
    "@release-it/keep-a-changelog": "^7.0.1",
    "@types/debug": "4.1.13",
    "@types/mime-types": "^3.0.1",
    "@types/node": "20.19.39",
    "eslint": "^10.3.0",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-visual-complexity": "0.1.4",
    "globals": "^17.6.0",
    "knip": "^6.12.0",
    "lint-staged": "16.4.0",
    "markdown-magic": "^4.8.0",
    "prettier": "^3.8.3",
    "publint": "^0.3.19",
    "release-it": "19.2.4",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "prettier": {
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": true,
    "printWidth": 100,
    "semi": true,
    "trailingComma": "all",
    "bracketSpacing": true
  },
  "keywords": [
    "playwright",
    "network",
    "cache",
    "testing",
    "e2e"
  ],
  "license": "MIT"
}
